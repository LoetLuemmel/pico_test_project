{
    "configurations": [
        {
            "name": "Pico",
            "includePath": [
                "${workspaceFolder}/**",
                "${userHome}/pico-sdk/src/**/include",
                "${userHome}/pico-sdk/src/common/pico_stdlib/include",
                "${userHome}/pico-sdk/src/common/pico_base_headers/include",
                "${userHome}/pico-sdk/src/rp2_common/hardware_gpio/include",
                "${userHome}/pico-sdk/src/rp2_common/hardware_adc/include",
                "${userHome}/pico-sdk/src/rp2_common/pico_platform/include",
                "${userHome}/pico-sdk/src/rp2040/pico_platform/include",
                "${userHome}/pico-sdk/src/rp2040/hardware_regs/include",
                "${userHome}/pico-sdk/src/rp2040/hardware_structs/include",
                "${userHome}/pico-sdk/src/boards/include",
                "${workspaceFolder}/build/generated/pico_base",
                "${workspaceFolder}/build/generated/pico_base/pico"
            ],
            "defines": [
                "PICO_BOARD=\"pico\"",
                "PICO_BUILD=1",
                "PICO_NO_HARDWARE=0",
                "PICO_ON_DEVICE=1",
                "LIB_PICO_STDIO_USB=1"
            ],
            "compilerPath": "/usr/local/bin/arm-none-eabi-gcc",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-arm"
        }
    ],
    "version": 4
}
